# Build-time PUBLIC vars — baked into the client bundle by Astro/Vite.
# Copy to .env for local dev; set the same two in your Cloudflare build env.
# The anon key is public by design (RLS does the real protection), so it is safe
# to ship in the browser bundle. NEVER put the service-role key here — there is
# no service-role key in this project at all.
#
# These power browser-side Google sign-in (src/lib/authClient.ts). The SSR
# endpoints read their own copies from wrangler [vars] / .dev.vars at runtime.

PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
