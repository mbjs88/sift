---
// Sign-in gate. Static shell; the script hydrates the session, redirects if
// already signed in, and otherwise wires the Google sign-in button.
export const prerender = true;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#efe8dc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#131019" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <title>Sift — your kitchen, distilled</title>
  </head>
  <body>
    <div class="app-bg" aria-hidden="true"><div class="lift"></div></div>

    <main class="min-h-dvh flex flex-col items-center justify-center gap-8 px-6 py-12">
      <div class="glass-strong rise w-full max-w-md px-7 py-9 flex flex-col items-center text-center gap-6">
        <div class="flex items-baseline gap-1.5">
          <span class="text-4xl tracking-[-0.04em]" style="font-weight:600">Sift</span>
          <span class="w-2 h-2 rounded-full mb-1" style="background:var(--color-ember)"></span>
        </div>

        <div class="space-y-2">
          <h1 class="text-2xl tracking-[-0.03em]" style="font-weight:600">Your kitchen, distilled.</h1>
          <p class="text-[color:var(--color-ink-soft)] text-balance">
            Save recipes, cooking videos and food blogs in one tap. Sift reads them,
            keeps only what matters, and lets you ask your own collection anything.
          </p>
        </div>

        <ul class="w-full flex flex-col gap-2 text-sm text-left">
          <li class="flex items-center gap-3">
            <span class="dot">1</span> Share or paste a link — it’s saved instantly.
          </li>
          <li class="flex items-center gap-3">
            <span class="dot">2</span> Sift distills the recipe, technique and wisdom.
          </li>
          <li class="flex items-center gap-3">
            <span class="dot">3</span> Ask “what can I make with…?” and cook.
          </li>
        </ul>

        <button id="signin" class="action w-full px-6 py-3 text-sm font-medium flex items-center justify-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21.35 11.1h-9.18v2.92h5.27c-.23 1.4-1.64 4.1-5.27 4.1-3.17 0-5.76-2.62-5.76-5.85s2.59-5.85 5.76-5.85c1.8 0 3.01.77 3.7 1.43l2.52-2.43C16.99 3.58 14.76 2.6 12.17 2.6 6.97 2.6 2.75 6.82 2.75 12.27s4.22 9.67 9.42 9.67c5.44 0 9.04-3.82 9.04-9.2 0-.62-.07-1.09-.16-1.64Z"/></svg>
          Continue with Google
        </button>
        <p id="status" class="text-xs text-[color:var(--color-ink-soft)] min-h-4"></p>
      </div>

      <p class="text-xs text-[color:var(--color-ink-soft)]/70">Private to you. Your data, your account.</p>
    </main>

    <style>
      .dot {
        display: grid; place-items: center;
        width: 1.4rem; height: 1.4rem; flex: none;
        border-radius: 9999px;
        background: color-mix(in srgb, var(--color-ember) 16%, transparent);
        color: var(--color-ember);
        font-size: .72rem; font-weight: 600;
      }
    </style>

    <script>
      import { bootstrapAuth, signInWithGoogle } from '../lib/authClient';

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }

      const btn = document.getElementById('signin') as HTMLButtonElement | null;
      const status = document.getElementById('status');

      // Bind the click handler IMMEDIATELY — never gate it behind the async
      // session check (that was the mobile bug: if bootstrap stalled, the button
      // stayed dead). The click always works; bootstrap only handles redirect.
      btn?.addEventListener('click', async () => {
        if (status) status.textContent = 'Opening Google…';
        try {
          await signInWithGoogle('/app');
        } catch {
          if (status) status.textContent = 'Couldn’t start sign-in. Try again.';
        }
      });

      bootstrapAuth()
        .then((signedIn) => { if (signedIn) window.location.replace('/app'); })
        .catch(() => {/* stay on the gate; the button still works */});
    </script>
  </body>
</html>
