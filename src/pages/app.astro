---
// The synthesis workspace. The shell is static; the island (client:only) reads
// the browser session and drives RAG retrieval + the knowledge graph. SSR auth
// gating lands with full OAuth — for now the island prompts to sign in if it
// finds no session.
export const prerender = true;
import '../styles/global.css';
import SynthesisApp from '../components/SynthesisApp.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#e9e2d6" />
    <link rel="manifest" href="/manifest.json" />
    <title>Sift — Synthesis</title>
  </head>
  <body>
    <main class="min-h-dvh flex flex-col items-center gap-12 px-6 py-16">
      <a href="/" class="text-2xl tracking-tight" style="font-weight:200">Sift</a>
      <SynthesisApp client:only="react" />
    </main>

    <script>
      import { bootstrapAuth } from '../lib/authClient';

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }

      // Hydrate the session (also consumes the OAuth redirect hash on first
      // landing) and seed the sb-access-token cookie before the island fetches.
      // No session -> back to the sign-in gate.
      bootstrapAuth().then((signedIn) => {
        if (!signedIn) window.location.replace('/');
      });
    </script>
  </body>
</html>
